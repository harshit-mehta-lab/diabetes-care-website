{
  "project": {
    "name": "Diabetes Care Website",
    "version": "1.0.0",
    "developer": "Harshit Mehta",
    "repository": "https://github.com/harshit-mehta-lab/diabetes-care-website"
  },

  "application": {
    "frontend": {
      "folders": ["css", "js", "images", "public"],
      "description": "User interface for diabetes care web application"
    },

    "backend": {
      "folder": "Server",
      "runtime": "Node.js",
      "description": "Handles API and application logic"
    }
  },

  "devops": {
    "version_control": "Git",
    "repository_hosting": "GitHub",
    "ci_cd": "GitHub Actions",
    "containerization": "Docker"
  },

  "deployment": {
    "environment": "production",
    "container_port": 3000,
    "workflow_file": ".github/workflows/docker-ci.yml"
  },

  "branches": [
    "production",
    "feature-api",
    "feature-ui"
  ]
}
